#pragma once
#include "misc_language.h"

#define ARQMA_VERSION_TAG "@VERSIONTAG@"

#define ARQMA_MAJOR_VERSION "7"
#define ARQMA_MINOR_VERSION "1"
#define ARQMA_PATCH_NO "0"

#define ARQMA_RELEASE_NAME "Fallen Angel"

#define ARQMA_VERSION ARQMA_MAJOR_VERSION "." ARQMA_MINOR_VERSION "." ARQMA_PATCH_NO

#define ARQMA_VERSION_FULL ARQMA_VERSION "-" ARQMA_VERSION_TAG

#define ARQMA_VERSION_IS_RELEASE @VERSION_IS_RELEASE@

#include "version.h"

const char* const ARQMA_VERSION_TAG = ARQMA_VERSION_TAG;
const char* const ARQMA_VERSION = ARQMA_VERSION;
const char* const ARQMA_RELEASE_NAME = ARQMA_RELEASE_NAME;
const char* const ARQMA_VERSION_FULL = ARQMA_VERSION_FULL;
const bool ARQMA_VERSION_IS_RELEASE = ARQMA_VERSION_IS_RELEASE;
